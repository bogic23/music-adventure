<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Adventure" />

    <style name="Adventure.AnswerButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_dark</item>
        <item name="backgroundTint">@color/surface_answer</item>
        <item name="strokeColor">@color/gold_primary</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/gold_light</item>
        <item name="iconTint">@color/cyan_dark</item>
    </style>

    <style name="Adventure.HeaderTitle">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Adventure.HeaderSubtitle">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Adventure.SectionLabel">
        <item name="android:textColor">@color/cyan_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Adventure.QuestionText">
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">8dp</item>
    </style>

    <style name="Adventure.HintText">
        <item name="android:textColor">@color/text_light</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
</resources>
